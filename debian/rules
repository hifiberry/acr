#!/usr/bin/make -f

export DH_VERBOSE=1
export SKIP_BUILD
export CARGO_HOME = $(CURDIR)/debian/cargo_home
export RUSTUP_HOME = $(CURDIR)/debian/rustup_home

# Minimum rustc that can compile these sources: they use trait upcasting,
# stabilised in Rust 1.86. Anything older fails with E0658 regardless of which
# dependency versions are selected. Keep in sync with rust-version in Cargo.toml.
RUST_MIN_VERSION = 1.86

# Optimize Rust compilation for space efficiency
export CARGO_BUILD_JOBS = 1
export CARGO_INCREMENTAL = 0
export RUST_BACKTRACE = 0

%:
	dh $@

override_dh_auto_configure:
	# Install Rust via rustup if the system toolchain is missing or too old.
	#
	# Check rustc, not cargo: it is rustc's version that decides whether the
	# sources compile, and the two can be a mismatched pair (a build host with a
	# newer cargo in /usr/local/bin alongside the distribution's older rustc in
	# /usr/bin passes a cargo-only check while still failing to build).
	#
	# Compare versions numerically rather than by pattern. The previous check
	# accepted any 1.80-1.99, so it silently accepted a rustc too old to build
	# this crate and then never installed a working toolchain.
	set -e; \
	rustc_version=$$(rustc --version 2>/dev/null | awk '{print $$2}'); \
	if [ -n "$$rustc_version" ] && \
	   [ "$$(printf '%s\n%s\n' "$(RUST_MIN_VERSION)" "$$rustc_version" | sort -V | head -n1)" = "$(RUST_MIN_VERSION)" ]; then \
		echo "Using system rustc $$rustc_version (>= $(RUST_MIN_VERSION))"; \
	else \
		echo "System rustc ($${rustc_version:-not found}) is older than $(RUST_MIN_VERSION); installing a toolchain via rustup"; \
		mkdir -p $(RUSTUP_HOME) $(CARGO_HOME); \
		curl https://sh.rustup.rs -sSf | \
		RUSTUP_HOME=$(RUSTUP_HOME) CARGO_HOME=$(CARGO_HOME) \
		sh -s -- -y --no-modify-path; \
	fi

override_dh_auto_build:
	if [ "$$SKIP_BUILD" = "1" ]; then \
		echo "Skipping cargo build as requested"; \
	else \
		export CARGO_BUILD_JOBS=1; \
		export CARGO_TARGET_DIR=$(CURDIR)/target; \
		export TMPDIR=$(CURDIR)/build_tmp; \
		export HOME=$(CURDIR)/build_home; \
		export RUST_BACKTRACE=0; \
		mkdir -p $(CURDIR)/build_tmp $(CURDIR)/build_home; \
		echo "Fetching dependencies..."; \
		PATH="$(CARGO_HOME)/bin:$(PATH)" cargo fetch || exit 1; \
		echo "Building with Cargo..."; \
		PATH="$(CARGO_HOME)/bin:$(PATH)" cargo build --release --jobs 1 || exit 1; \
		echo "Build completed successfully"; \
		find $(CURDIR)/target -name "*.rlib" -delete 2>/dev/null || true; \
		find $(CURDIR)/target -name "*.rmeta" -delete 2>/dev/null || true; \
		rm -rf $(CURDIR)/build_tmp $(CURDIR)/build_home; \
	fi

override_dh_auto_install:
	# Create required directories
	mkdir -p debian/hifiberry-audiocontrol/usr/bin
	mkdir -p debian/hifiberry-audiocontrol/usr/share/hifiberry-audiocontrol
	mkdir -p debian/hifiberry-audiocontrol/etc/audiocontrol
	# Debug: List target directory contents
	echo "Contents of target/release directory:"; \
	ls -la target/release/ || echo "target/release directory not found"
	# Install main binary
	if [ -f target/release/audiocontrol ]; then \
		echo "Installing main audiocontrol binary"; \
		cp target/release/audiocontrol debian/hifiberry-audiocontrol/usr/bin/audiocontrol; \
		chmod +x debian/hifiberry-audiocontrol/usr/bin/audiocontrol; \
	else \
		echo "Error: Main binary target/release/audiocontrol not found!"; \
		echo "Build may have failed - check for cargo build errors above"; \
		exit 1; \
	fi
	# Install CLI tools if they exist
	for tool in audiocontrol_lms_client audiocontrol_musicbrainz_client audiocontrol_send_update audiocontrol_dump_store audiocontrol_dump_cache audiocontrol_notify_librespot audiocontrol_player_event_client audiocontrol_list_mpris_players audiocontrol_get_mpris_state audiocontrol_monitor_mpris_state audiocontrol_listen_shairportsync audiocontrol_favourites audiocontrol_input_devices; do \
		if [ -f "target/release/$$tool" ]; then \
			cp "target/release/$$tool" "debian/hifiberry-audiocontrol/usr/bin/$$tool"; \
			chmod +x "debian/hifiberry-audiocontrol/usr/bin/$$tool"; \
		fi; \
	done
	# Install Python now playing client
	if [ -f example/python/audiocontrol_nowplaying.py ]; then \
		cp example/python/audiocontrol_nowplaying.py debian/hifiberry-audiocontrol/usr/bin/audiocontrol_nowplaying; \
		chmod +x debian/hifiberry-audiocontrol/usr/bin/audiocontrol_nowplaying; \
	fi
	# Install pause-all script
	if [ -f scripts/pause-all ]; then \
		cp scripts/pause-all debian/hifiberry-audiocontrol/usr/bin/pause-all; \
		chmod +x debian/hifiberry-audiocontrol/usr/bin/pause-all; \
	fi
	# Install default configuration files
	if [ -f configs/audiocontrol.json ]; then \
		cp configs/audiocontrol.json debian/hifiberry-audiocontrol/etc/audiocontrol/; \
	fi
	if [ -f configs/logging.json ]; then \
		cp configs/logging.json debian/hifiberry-audiocontrol/etc/audiocontrol/; \
	fi
	# Install genres configuration
	if [ -f configs/genres.json ]; then \
		cp configs/genres.json debian/hifiberry-audiocontrol/etc/audiocontrol/; \
	fi

override_dh_auto_clean:
	dh_auto_clean
	# Comprehensive cleanup to free space
	rm -rf target/
	rm -rf $(CARGO_HOME)
	rm -rf $(RUSTUP_HOME)
	rm -rf $(CURDIR)/build_tmp
	rm -rf $(CURDIR)/build_home
	rm -rf debian/.debhelper/
	rm -f debian/*.debhelper.log
	rm -f debian/*.postrm.debhelper
	rm -f debian/*.substvars
	# Cargo.lock is a committed source file, not a build artefact: deleting it
	# made every package build re-resolve dependencies to the newest
	# semver-compatible versions. That is non-reproducible, and it raises the
	# rustc needed at build time to whatever the newest dependencies demand
	# today rather than what this crate was tested against.
	find . -name "*.rlib" -delete 2>/dev/null || true
	find . -name "*.rmeta" -delete 2>/dev/null || true

override_dh_installsystemd:
	dh_installsystemd --name=audiocontrol --restart-after-upgrade

override_dh_strip:
	# Skip debug symbol extraction - don't create dbgsym package
	dh_strip --no-automatic-dbgsym
